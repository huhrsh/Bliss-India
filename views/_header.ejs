<link rel="stylesheet" href="/css/header.css">

<header>
    <div class="company-logo">
        <a href="/"><img src="/Images/Bliss India Logo.jpg">Bliss India</a>
    </div>
    <div class="search-bar">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" required class="search-input">
    </div>
    <div class="user-options">
        <div class="wishlist">
            <i class="fa-solid fa-heart"></i> wishlist
        </div>
        <div class="cart">
            <i class="fa-solid fa-cart-shopping"></i> Cart
        </div>
        <%if(locals.user){%>
            <div class="user"><i class="fa-solid fa-user"></i>
                <%=user.name.split(' ')[0]%>
            </div>
        <%}else{%>
            <div class="user"><i class="fa-solid fa-user"></i>User</div>
        <%}%>
    </div>
</header>

<section class="nav-bar">
    <div class="category"><a href="/products/crystal-collection">Crystal Collection</a></div>
    <div class="category" id="pendant"><div class="pendant-hover">
        <div id="hover-loader"></div>
        <div class="pendant-categories"><a href="">Premium Pendants</a></div>
        <div class="pendant-categories"><a href="">Minimal Pendants</a></div>
        <div class="pendant-categories"><a href="">Silver Pendants</a></div>
        <div class="pendant-categories"><a href="">Charm Pendants</a></div>
    </div>
    <a href="/products/pendants">Pendants</a></div>
    <div class="category"><a href="/products/lockets">Lockets</a></div>
    <div class="category"><a href="/products/earrings">Earrings</a></div>
    <div class="category"><a href="/products/bracelets">Bracelets</a></div>
    <div class="category"><a href="/products/rings">Rings</a></div>
    <div class="category"><a href="/products/complete-sets">Complete Sets</a></div>
    <div class="category"><a href="/products/evil-eye-collection">Evil Eye Collection</a></div>
    <div class="category"><a href="/products/offers">Offers</a></div>
</section>
<hr>


