<div class="pendant-hover">
    <div ><a href="">Premium Pendants</a></div>
    <div ><a href="">Minimal Pendants</a></div>
    <div ><a href="">Silver Pendants</a></div>
    <div><a href="">Charm Pendants</a></div>
</div>

<script>
    const navBar=document.getElementsByClassName('category');
    const pendantHover=document.getElementsByClassName('pendant-hover')[0];
    navBar[1].onmouseenter=()=>{
        pendantHover.style.display='flex';
        pendantHover.classList.add('animate__faster');
        pendantHover.classList.remove('animate__fadeOut');
        pendantHover.classList.add('animate__animated');
        pendantHover.classList.add('animate__fadeIn');
        pendantHover.onmouseenter=()=>{
            console.log("inside");
            pendantHover.style.display='flex';
        }
        pendantHover.onmouseleave=(e)=>{
            console.log("outside");
            pendantHover.classList.remove('animate__fadeIn');
            pendantHover.classList.add('animate__fadeOut');    
        }
    }
    // navBar[1].onmouseleave=()=>{
    //     pendantHover.classList.remove('animate__fadeIn');
    //     pendantHover.classList.add('animate__fadeOut');
    // }
</script>