<style>
        .nav-bar{
            width: 100%;
            padding: 0.5% 7%;
            font-size: 1.6rem;
            display: flex;
            align-items: center;
            justify-content: space-evenly;
            top: 0;
            position: sticky;
        }

        .nav-bar>div{
            padding: 0.5% 1%;
            border-radius: 3rem;
        }

        .nav-bar>div:hover{
            background-color: #333;
            background: -webkit-linear-gradient(60deg,#a0c4ff,#9bf6ff);
            border-radius: 3vh;
