        .pendant-hover{
            /* visibility: hidden; */
            border-radius: 0.5rem ;
            background: white;
            display: none;
            flex-direction: column;
            height: auto;
            width: 15vw;
            top: 17vh;
            left: 18vw;
            position: absolute;
            border-top: 2px solid #333;
            z-index: 2; 
        }
        .pendant-hover>div{
            width: 15vw;
            font-size: 1.6rem;
