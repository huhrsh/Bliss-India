<link rel="stylesheet" href="/css/signIn.css">

<section class="sign-in-container">
    <h3 class="sign-in-heading">
        Please enter the code sent to your email account
    </h3>
    <form action="/users/enter-OTP?otp=<%=OTP%>" class="sign-in-form">
        <input type="text" name="otp" placeholder="OTP" required>
        <input type="submit" id="sign-in" value="Get OTP">
    </form>
</section>

<script type="text/javascript" src="/js/signUp.js"></script>