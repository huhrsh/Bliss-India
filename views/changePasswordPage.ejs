
<link rel="stylesheet" href="/css/changePasswordPage.css">


<div class="outer-container">
    <form action="/users/change-password?id=<%=user.id%>" method="post" class="change-form">    
        <div class="change-div">
            <label>Old Password:</label><input type="password" placeholder="Current password" name="old_password" required>
        </div>
        <div class="change-div">
            <label>New Password:</label><input type="password" name="new_password" placeholder="New password" required>
        </div>
        <div class="change-div">
            <label>Confirm New Password:</label><input type="text" placeholder="Confirm new password" name="confirm_password">
        </div>
        <input type="submit" value="Change Password" class="change-password">
    </form>

</div>

<script type="text/javascript" src="/js/changePasswordPage.js"></script>
